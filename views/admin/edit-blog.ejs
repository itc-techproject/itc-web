<section class="admin-form-section">
  <div class="admin-form-container">

    <div class="admin-form-header">
      <h1>Edit Artikel</h1>
    </div>

    <form action="/admin/edit/<%= blog._id %>" method="POST" class="admin-form">

      <div class="form-group">
        <label>Judul</label>
        <input type="text" name="title" value="<%= blog.title %>" required>
      </div>

      <div class="form-group">
        <label>URL Gambar</label>
        <input type="text" name="image" value="<%= blog.image %>">
      </div>

      <div class="form-group">
        <label>Kategori</label>
        <input type="text" name="category" value="<%= blog.category %>">
      </div>

      <div class="form-group">
        <label>Excerpt</label>
        <input type="text" name="excerpt" value="<%= blog.excerpt %>">
      </div>

      <div class="form-group">
        <label>Content</label>
        <textarea name="content" rows="10" required><%= blog.content %></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Update</button>
        <a href="/admin/dashboard" class="btn-secondary">Batal</a>
      </div>

    </form>

  </div>
</section>