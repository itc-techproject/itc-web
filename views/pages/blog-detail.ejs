<% css = '<link rel="stylesheet" href="/css/blog.css">' %>
<% script  = '<script src="/js/page-blog.js" defer></script>' %>

<section class="blog-detail">
  <div class="container">
    <h1><%= blog.title %></h1>
    <p><%= blog.date %> • <%= blog.author %></p>
    <img src="<%= blog.image %>" alt="">
    <div class="content">
      <%= blog.content %>
    </div>
  </div>
</section>