  <!-- ABOUT -->
  <section class="section about" id="about" data-aos="fade-up">
    <div class="container">
      <h2 class="section-title">ABOUT US</h2>
      <p class="section-description">
        ITC MIPA Unsoed merupakan unit kegiatan mahasiswa yang berada di lingkup Fakultas MIPA Unsoed
        yang bergerak di bidang informasi, teknologi, dan komunikasi serta IPTEK.
      </p>
    </div>
  </section>

  <!-- VISI MISI -->
  <section class="section glass-section" data-aos="fade-up">
    <div class="container two-column">

      <div class="card">
        <h3>Visi</h3>
        <p>
          Menjadi Unit Kemahasiswaan terdepan di Fakultas MIPA Universitas Jenderal Soedirman
          dalam mewujudkan atmosfer kampus berbasis IPTEK.
        </p>
      </div>

      <div class="card">
        <h3>Misi</h3>
        <ol>
          <li>Mewadahi mahasiswa MIPA Unsoed di bidang ITC.</li>
          <li>Mengembangkan kegiatan edukasi, sosial, dan riset.</li>
          <li>Meningkatkan kreativitas dan keahlian mahasiswa.</li>
          <li>Membina kebersamaan antar anggota.</li>
          <li>Mengembangkan potensi IPTEK masyarakat.</li>
        </ol>
      </div>

    </div>
  </section>

  <!-- DIVISI -->
  <section class="section divisi" data-aos="fade-up">
    <div class="container two-column align-center">

      <div class="image-frame">
        <img src="/images/home_divisi.webp" alt="Divisi ITC">
      </div>

      <div>
        <h2 class="section-title">Divisi</h2>
        <p class="section-text">
          ITC memiliki 5 divisi yaitu pengurus harian, divisi informasi,
          divisi teknologi, divisi komunikasi, dan divisi pengembangan.
        </p>
        <a href="/divisi" class="btn-outline">Selengkapnya</a>
      </div>

    </div>
  </section>

  <!-- HISTORY -->
  <section class="section glass-section" data-aos="fade-up">
    <div class="container two-column align-center">

      <div>
        <h2 class="section-title">SEJARAH</h2>
        <p class="section-text">
          UKM ITC MIPA UNSOED berdiri sejak tahun 2006. Awalnya terbentuk sebagai
          "ITC Community" dan kini resmi menjadi UKM aktif yang memajukan IPTEK di MIPA.
        </p>

        <div class="button-group">
          <a href="/history" class="btn-outline">Selengkapnya</a>
          <a href="/blog" class="btn-modern">Lihat Blog</a>
        </div>
      </div>

      <div class="image-frame">
        <img src="/images/home_history.webp" alt="History ITC">
      </div>

    </div>
  </section>

