<% css = '<link rel="stylesheet" href="/css/blog.css">' %>
<% script  = '<script src="/js/page-blog.js" defer></script>' %>

<section class="blog">
  <div class="blog-container">

    <!-- HEADER -->
    <div class="blog-header">
      <div class="blog-title">
        <h1>Artikel <span>Terbaru</span></h1>
        <p>Temukan berbagai insight, event, dan aktivitas terbaru dari kami.</p>
      </div>

      <div class="blog-search-filter">

        <!-- TOP BAR (Search + Icon) -->
        <div class="top-bar">
          <div class="search-wrapper">

            <input type="text" 
                  placeholder="Cari artikel..." 
                  class="search-input">

            <button class="search-btn">
              <i class="bi bi-search"></i>
            </button>

          </div>

          <button class="mobile-filter-toggle">
            <i class="bi bi-funnel"></i>
          </button>
        </div>

        <!-- FILTER GROUP -->
        <div class="filter-group">
          <button class="filter-btn active" data-category="semua">Semua</button>
          <button class="filter-btn" data-category="event">Event</button>
          <button class="filter-btn" data-category="aktivitas">Aktivitas</button>
          <button class="filter-btn" data-category="teknologi">Teknologi</button>
          <button class="filter-btn" data-category="informasi">Informasi</button>
          <button class="filter-btn" data-category="komunikasi">Komunikasi</button>
          <button class="filter-btn" data-category="pengembangan">Pengembangan</button>
          <button class="filter-btn" data-category="lainnya">Lainnya</button>
        </div>

      </div>
    </div>

    <!-- BLOG GRID -->
    <div class="blog-grid">

    <% blogs.forEach(function(blog) { %>

        <a href="/blog/<%= blog.slug %>" class="blog-link">
        <article class="blog-card">

            <div class="blog-image">
            <img src="<%= blog.image %>" alt="">
            <span class="category-badge"><%= blog.category %></span>
            </div>

            <div class="blog-content">
            <div class="blog-meta">
                <span><%= blog.createdAt.toDateString() %></span>
                <span>•</span>
                <span><%= blog.author %></span>
            </div>

            <h3 class="blog-title-card">
                <%= blog.title %>
            </h3>

            <p>
                <%= blog.excerpt %>
            </p>
            </div>

        </article>
        </a>

    <% }) %>

      <div class="scroll-loader">
        <p>Loading...</p>
      </div>

    </div>

  </div>
</section>